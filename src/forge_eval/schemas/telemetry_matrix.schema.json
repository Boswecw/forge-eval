{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_version",
    "kind",
    "run",
    "reviewers",
    "defects",
    "matrix",
    "summary",
    "provenance"
  ],
  "properties": {
    "artifact_version": {"type": "integer", "const": 1},
    "kind": {"type": "string", "const": "telemetry_matrix"},
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "repo_path",
        "base_ref",
        "head_ref",
        "base_commit",
        "head_commit",
        "review_findings_artifact"
      ],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "repo_path": {"type": "string", "minLength": 1},
        "base_ref": {"type": "string", "minLength": 1},
        "head_ref": {"type": "string", "minLength": 1},
        "base_commit": {"type": "string", "minLength": 1},
        "head_commit": {"type": "string", "minLength": 1},
        "review_findings_artifact": {"type": "string", "const": "review_findings.json"}
      }
    },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "reviewer_id",
          "status",
          "kind",
          "eligible",
          "usable",
          "failed",
          "skipped",
          "findings_emitted",
          "slices_seen",
          "error"
        ],
        "properties": {
          "reviewer_id": {"type": "string", "minLength": 1},
          "status": {"type": "string", "enum": ["ok", "failed", "skipped"]},
          "kind": {"type": "string", "enum": ["changed_lines", "documentation_consistency", "structural_risk"]},
          "eligible": {"type": "boolean"},
          "usable": {"type": "boolean"},
          "failed": {"type": "boolean"},
          "skipped": {"type": "boolean"},
          "findings_emitted": {"type": "integer", "minimum": 0},
          "slices_seen": {"type": "integer", "minimum": 0},
          "error": {"type": ["string", "null"]}
        }
      }
    },
    "defects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["defect_key", "reported_by", "support_count"],
        "properties": {
          "defect_key": {"type": "string", "pattern": "^dfk_[a-f0-9]{64}$"},
          "file_path": {"type": "string", "minLength": 1},
          "category": {
            "type": "string",
            "enum": ["correctness", "consistency", "schema", "docs", "policy", "risk", "unknown"]
          },
          "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
          "reported_by": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "support_count": {"type": "integer", "minimum": 1}
        }
      }
    },
    "matrix": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["defect_key", "observations", "k_eff_defect"],
        "properties": {
          "defect_key": {"type": "string", "pattern": "^dfk_[a-f0-9]{64}$"},
          "observations": {
            "type": "object",
            "additionalProperties": {
              "anyOf": [
                {"type": "integer", "enum": [0, 1]},
                {"type": "null"}
              ]
            }
          },
          "k_eff_defect": {"type": "integer", "minimum": 0}
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "k_configured",
        "k_executed",
        "k_failed",
        "k_skipped",
        "k_usable",
        "k_eff",
        "defect_count",
        "matrix_rows",
        "cells_observed",
        "cells_missed",
        "cells_null"
      ],
      "properties": {
        "k_configured": {"type": "integer", "minimum": 0},
        "k_executed": {"type": "integer", "minimum": 0},
        "k_failed": {"type": "integer", "minimum": 0},
        "k_skipped": {"type": "integer", "minimum": 0},
        "k_usable": {"type": "integer", "minimum": 0},
        "k_eff": {"type": "integer", "minimum": 0},
        "defect_count": {"type": "integer", "minimum": 0},
        "matrix_rows": {"type": "integer", "minimum": 0},
        "cells_observed": {"type": "integer", "minimum": 0},
        "cells_missed": {"type": "integer", "minimum": 0},
        "cells_null": {"type": "integer", "minimum": 0}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "deterministic", "inputs", "applicability_mode", "k_eff_mode"],
      "properties": {
        "algorithm": {"type": "string", "const": "telemetry_matrix_v1"},
        "deterministic": {"type": "boolean"},
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "enum": ["review_findings.json"]}
        },
        "applicability_mode": {"type": "string", "const": "reviewer_kind_scope_v1"},
        "k_eff_mode": {"type": "string", "const": "global_min_per_defect"}
      }
    }
  }
}
