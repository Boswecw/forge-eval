{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_version",
    "kind",
    "run",
    "reviewers",
    "findings",
    "summary",
    "provenance"
  ],
  "properties": {
    "artifact_version": {"type": "integer", "const": 1},
    "kind": {"type": "string", "const": "review_findings"},
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_id",
        "repo_path",
        "base_ref",
        "head_ref",
        "base_commit",
        "head_commit",
        "slice_artifact",
        "risk_artifact"
      ],
      "properties": {
        "run_id": {"type": "string", "minLength": 1},
        "repo_path": {"type": "string", "minLength": 1},
        "base_ref": {"type": "string", "minLength": 1},
        "head_ref": {"type": "string", "minLength": 1},
        "base_commit": {"type": "string", "minLength": 1},
        "head_commit": {"type": "string", "minLength": 1},
        "slice_artifact": {"type": "string", "const": "context_slices.json"},
        "risk_artifact": {"type": ["string", "null"], "enum": ["risk_heatmap.json", null]}
      }
    },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["reviewer_id", "kind", "status", "slices_seen", "findings_emitted", "error"],
        "properties": {
          "reviewer_id": {"type": "string", "minLength": 1},
          "kind": {"type": "string", "enum": ["changed_lines", "documentation_consistency", "structural_risk"]},
          "status": {"type": "string", "enum": ["ok", "failed", "skipped"]},
          "slices_seen": {"type": "integer", "minimum": 0},
          "findings_emitted": {"type": "integer", "minimum": 0},
          "error": {"type": ["string", "null"]}
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "defect_key",
          "reviewer_id",
          "file_path",
          "slice_id",
          "title",
          "severity",
          "category"
        ],
        "properties": {
          "defect_key": {"type": "string", "pattern": "^dfk_[a-f0-9]{64}$"},
          "reviewer_id": {"type": "string", "minLength": 1},
          "slice_id": {"type": "string", "minLength": 1},
          "file_path": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "description": {"type": ["string", "null"]},
          "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
          "confidence": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
          "category": {
            "type": "string",
            "enum": ["correctness", "consistency", "schema", "docs", "policy", "risk", "unknown"]
          },
          "line_start": {"type": ["integer", "null"], "minimum": 1},
          "line_end": {"type": ["integer", "null"], "minimum": 1},
          "evidence": {
            "type": "object",
            "additionalProperties": false,
            "required": ["anchors", "signals"],
            "properties": {
              "anchors": {"type": "array", "items": {"type": "string", "minLength": 1}},
              "signals": {"type": "array", "items": {"type": "string", "minLength": 1}}
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reviewer_count",
        "reviewer_ok_count",
        "reviewer_failed_count",
        "reviewer_skipped_count",
        "finding_count",
        "finding_count_by_severity"
      ],
      "properties": {
        "reviewer_count": {"type": "integer", "minimum": 0},
        "reviewer_ok_count": {"type": "integer", "minimum": 0},
        "reviewer_failed_count": {"type": "integer", "minimum": 0},
        "reviewer_skipped_count": {"type": "integer", "minimum": 0},
        "finding_count": {"type": "integer", "minimum": 0},
        "finding_count_by_severity": {
          "type": "object",
          "additionalProperties": false,
          "required": ["low", "medium", "high", "critical"],
          "properties": {
            "low": {"type": "integer", "minimum": 0},
            "medium": {"type": "integer", "minimum": 0},
            "high": {"type": "integer", "minimum": 0},
            "critical": {"type": "integer", "minimum": 0}
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "deterministic", "reviewer_failure_policy", "inputs"],
      "properties": {
        "algorithm": {"type": "string", "const": "reviewer_execution_v1"},
        "deterministic": {"type": "boolean"},
        "reviewer_failure_policy": {"type": "string", "enum": ["fail_stage", "record_and_continue"]},
        "inputs": {
          "type": "array",
          "items": {"type": "string", "enum": ["context_slices.json", "risk_heatmap.json"]},
          "minItems": 1
        }
      }
    }
  }
}
