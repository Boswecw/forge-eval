{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "run_id",
    "artifact_manifest",
    "hashchain",
    "final_sha256",
    "provenance"
  ],
  "properties": {
    "schema_version": {"type": "string", "const": "v1"},
    "kind": {"type": "string", "const": "evidence_bundle"},
    "run_id": {"type": "string", "minLength": 1},
    "artifact_manifest": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "sha256", "artifact_id"],
        "properties": {
          "kind": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "artifact_id": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
        }
      }
    },
    "hashchain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["chain_hashes", "final_chain_hash"],
      "properties": {
        "chain_hashes": {
          "type": "array",
          "items": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
          "minItems": 1
        },
        "final_chain_hash": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
      }
    },
    "final_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm"],
      "properties": {
        "algorithm": {"type": "string", "minLength": 1}
      }
    }
  }
}
